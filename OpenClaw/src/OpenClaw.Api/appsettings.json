{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "${ALLOWED_HOSTS}",
  "Database": {
    "Provider": "PostgreSql",
    "ConnectionString": "${DB_CONNECTION_STRING}",
    "DatabaseName": "OpenClaw"
  },
  "Authentication": {
    "Enabled": true
  },
  "JwtSettings": {
    "Secret": "${JWT_SECRET}",
    "TokenExpirationInMinutes": 10080,
    "Issuer": "OpenClaw",
    "Audience": "OpenClaw",
    "RefreshTokenExpiryInDays": 30
  },
  "EmailSettings": {
    "EnableEmailNotifications": false,
    "DefaultFromEmail": "",
    "SmtpSettings": {
      "Server": "",
      "Port": 0,
      "Username": "",
      "Password": ""
    }
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "OpenClaw",
    "ServiceVersion": "1.0.0",
    "Dashboard": "Aspire",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Skills": {
    "Directory": "/app/skills"
  },
  "Telegram": {
    "Enabled": false,
    "BotToken": "",
    "WebhookUrl": "",
    "SecretToken": "",
    "AllowedUserIds": []
  }
}